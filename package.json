{
  "name": "sync-claude-folder",
  "version": "1.0.0",
  "description": "CLI tool that syncs dot_claude from a dotfiles repo to ~/.claude / ~/.claude-work using chezmoi-like naming rules",
  "homepage": "https://github.com/tomacheese/sync-claude-folder",
  "bugs": {
    "url": "https://github.com/tomacheese/sync-claude-folder/issues"
  },
  "license": "MIT",
  "author": "Tomachi",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "url": "git@github.com:tomacheese/sync-claude-folder.git",
    "type": "git"
  },
  "scripts": {
    "start": "tsx ./src/main.ts",
    "dev": "tsx watch ./src/main.ts",
    "sync": "tsx ./src/main.ts sync",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "fix": "run-z fix:prettier,fix:eslint",
    "lint:prettier": "prettier --check src",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "lint:tsc": "tsc",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "fix:prettier": "prettier --write src",
    "test": "jest --runInBand --passWithNoTests --detectOpenHandles --forceExit --coverage",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.14.55",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.3",
    "eslint": "10.6.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.2.1",
    "eslint-plugin-promise": "7.3.0",
    "jest": "30.4.2",
    "jest-expect-message": "1.1.3",
    "prettier": "3.9.5",
    "run-z": "2.1.0",
    "ts-jest": "29.4.11",
    "tsx": "4.23.0",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.10.0",
  "jest": {
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "moduleFileExtensions": ["js", "ts"],
    "setupFilesAfterEnv": ["jest-expect-message"],
    "testMatch": ["**/*.test.ts"],
    "collectCoverageFrom": ["src/**/*.ts", "!src/**/*.d.ts", "!src/main.ts"]
  }
}
